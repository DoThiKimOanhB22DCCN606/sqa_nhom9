                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "",
                  "// Lưu dữ liệu gốc từ object 'employee'",
                  "pm.collectionVariables.set('original_name', data.employee.name || '');",
                  "pm.collectionVariables.set('original_phone', data.employee.phone || '');",
                  "console.log('Saved baseline data for Rollback');"
                ],
                "type": "text/javascript",
