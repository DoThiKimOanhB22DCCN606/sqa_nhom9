        {
          "name": "AUTH10 - PUT Update (Check Output Auto)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const requestBody = JSON.parse(pm.request.body.raw);",
                  "const responseData = pm.response.json().data;",
                  "",
                  "pm.test('[Output Auto] Data trả về khớp 100% với Data gửi đi', () => {",
                  "    // So sánh dữ liệu gửi đi với dữ liệu nằm trong 'employee' trả về",
                  "    pm.expect(responseData.employee.name).to.equal(requestBody.name, 'Tên không được cập nhật');",
                  "    pm.expect(responseData.employee.phone).to.equal(requestBody.phone, 'SĐT không được cập nhật');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
