          "name": "JOB03-Create Position",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const authKey = pm.collectionVariables.get('sec_bearer_token');",
                  "const host = pm.variables.get('api_host') || 'http://localhost:8081';",
                  "pm.sendRequest({",
                  "  url: host + '/api/v1/job-service/recruitment-requests?status=APPROVED&page=1&limit=1',",
                  "  method: 'GET',",
                  "  header: { 'Authorization': 'Bearer ' + authKey }",
                  "}, function(err, res) {",
                  "  if (!err && res && res.code === 200) {",
                  "    const items = res.json().data && res.json().data.result ? res.json().data.result : [];",
                  "    if (items.length > 0) pm.collectionVariables.set('req_source_id', items[0].id);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Confirm resource creation - Status 200', () => pm.response.to.have.status(200));",
                  "const resourceObj = pm.response.json();",
                  "pm.test('Object contains valid identifier', () => pm.expect(resourceObj.data.id).to.be.a('number'));",
                  "pm.collectionVariables.set('vacancy_ref_id', resourceObj.data.id);"
                ],
                "type": "text/javascript"
              }
