  "item": [
    {
      "name": "1. Happy Path: Core Flow (Login -> Verify DB -> Rollback)",
      "item": [
        {
          "name": "AUTH01 - POST Login - Success Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Interface Testing",
                  "pm.test('[Interface] Status is 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "pm.test('[Interface] Content-Type is JSON', () => pm.response.to.have.header('Content-Type', 'application/json'));",
                  "",
                  "// 2. Body/Schema Verification",
                  "const body = pm.response.json();",
                  "pm.test('[Schema] Valid structure & Token exists', () => {",
                  "    pm.expect(body).to.have.property('data');",
                  "    pm.expect(body.data).to.have.property('access_token').that.is.a('string').and.not.empty;",
                  "});",
                  "",
                  "// Set variables for next steps",
                  "pm.collectionVariables.set('access_token', body.data.access_token);",
                  "// Đọc email người dùng vừa nhập lúc đăng nhập và lưu vào biến",
                  "const reqBody = JSON.parse(pm.request.body.raw);",
                  "pm.collectionVariables.set('current_login_email', reqBody.username);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"an.nguyen@company.com\", \"password\": \"123456\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user-service/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "user-service",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "AUTH02 - GET Profile - DB Verification",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Interface Testing",
                  "pm.test('[Interface] Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "// --- BẮT BUỘC PHẢI CÓ DÒNG NÀY ĐỂ ĐỌC DỮ LIỆU ---",
                  "const body = pm.response.json();",
                  "",
                  "// 2. Database Verification (Check Auto)",
                  "pm.test('[DB Verify] User data matches DB records', () => {",
                  "    // Tự động lấy email từ lúc login ra so sánh",
                  "    const expectedEmail = pm.collectionVariables.get('current_login_email') || 'an.nguyen@company.com';",
                  "    ",
                  "    // So sánh dữ liệu trả về",
                  "    pm.expect(body.data.email).to.equal(expectedEmail);",
                  "});",
                  "",
                  "",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user-service/users/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "user-service",
                "users",
                "1"
              ]
            }
          },
          "response": []
        },
        {
          "name": "AUTH03 - POST Logout - Execute Rollback",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Interface Testing",
                  "pm.test('[Interface] Status is 200 or 204', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));",
                  "",
                  "// 2. Rollback Execution",
                  "pm.test('[Rollback] Token invalidated locally', () => {",
                  "    pm.collectionVariables.set('access_token', '');",
                  "    pm.expect(pm.collectionVariables.get('access_token')).to.be.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user-service/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "user-service",
                "auth",
                "logout"
              ]
            }
          },
          "response": []
        }
      ]
