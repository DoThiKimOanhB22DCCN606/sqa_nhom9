        {
          "name": "WF07 - Get Tracking Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Fetch updated status post-transaction', () => pm.response.to.have.status(200));",
                  "const updateData = pm.response.json();",
                  "pm.test('Confirm valid state transition', () => {",
                  "  pm.expect(updateData.data.status).to.be.oneOf(['APPROVED', 'PENDING']);",
                  "});",
                  "pm.test('Integrity check: Record ID remains constant', () => {",
                  "  pm.expect(updateData.data.id).to.equal(parseInt(pm.collectionVariables.get('entry_ref_id')));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sec_bearer_token}}"
              }
