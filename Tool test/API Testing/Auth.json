    {
      "name": "2. Negative Tests: Login API",
      "item": [
        {
          "name": "AUTH04 - Login Fail - Invalid Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401 or 400', () => pm.expect(pm.response.code).to.be.oneOf([400, 401]));",
                  "",
                  "const msg = pm.response.json().message.toLowerCase();",
                  "",
                  "pm.test('Error contains correct keywords', () => {",
                  "    // Thêm chữ \"không hợp lệ\" vào danh sách tìm kiếm",
                  "    pm.expect(msg.match(/không hợp lệ|sai|không đúng|invalid/)).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"admin@gmail.com\", \"password\": \"wrongpass\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user-service/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "user-service",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
