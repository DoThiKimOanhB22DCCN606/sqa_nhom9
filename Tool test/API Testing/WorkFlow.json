          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Successful execution of approval logic', () => pm.response.to.have.status(200));",
                  "const stateInfo = pm.response.json();",
                  "pm.test('Validate transition to logical next state', () => {",
                  "  pm.expect(stateInfo.data.status).to.be.oneOf(['APPROVED', 'PENDING']);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sec_bearer_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
